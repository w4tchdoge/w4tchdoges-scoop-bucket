{
    "version": "0.19.0",
    "description": "A simple and elegant markdown editor",
    "homepage": "https://github.com/marktext/marktext",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/marktext/marktext/releases/download/v0.19.0/marktext-win-x64-0.19.0.zip",
            "hash": "c80806949e04fa355552c78c75737f7e8ecf1a388d32374f0e11525923b9d7b4"
        },
        "arm64": {
            "url": "https://github.com/marktext/marktext/releases/download/v0.19.0/marktext-win-arm64-0.19.0.zip",
            "hash": "162ef9bc4580a4e7fce52bd3f659f89d8d58921caff6d8532f885c9cfff982ec"
        }
    },
    "pre_install": [
        "New-Item -ItemType Directory -Path $dir -Name 'marktext-user-data' | Out-Null",
        "$persistUserData = Join-Path -Path $persist_dir -ChildPath 'marktext-user-data'",
        "if (-not (Test-Path $persistUserData -ErrorAction SilentlyContinue)) {",
        "    ensure $persistUserData | Out-Null",
        "} else {",
        "    Copy-Item \"$persistUserData\\*\" -Destination \"$dir\\marktext-user-data\" -Recurse",
        "}"
    ],
    "bin": "marktext.exe",
    "shortcuts": [
        [
            "marktext.exe",
            "MarkText"
        ]
    ],
    "pre_uninstall": [
        "$persistUserData = Join-Path -Path $persist_dir -ChildPath 'marktext-user-data'",
        "Copy-Item \"$dir\\marktext-user-data\\*\" -Destination $persistUserData -Recurse -Force"
    ],
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/marktext/marktext/releases/download/v$version/marktext-win-x64-$version.zip"
            },
            "arm64": {
                "url": "https://github.com/marktext/marktext/releases/download/v$version/marktext-win-arm64-$version.zip"
            }
        },
        "hash": {
            "url": "$baseurl/SHA256SUMS.txt"
        }
    }
}
